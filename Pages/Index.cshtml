@page
@model IndexModel
@{
    ViewData["Title"] = "Portfolio";
}

<div class="container py-5 portfolio-page">
    <header class="mb-5 text-center">
        
        <h1 class="display-5 fw-bold">Cikkkala Naga Veera Sai Ram</h1>
        <p class="lead">Software Engineer | Automotive AI Applications |AI Full-Stack Development | Cloud Solutions</p>
    </header>

    <section class="row gy-4">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm cardbox">
                <div class="card-body d-flex flex-column">
                    <h2 class="h5">Summary</h2>
                    <p class="flex-grow-1">Overview of my skills, background, and what I can deliver.</p>
                    <a class="btn btn-primary mt-3 align-self-start" asp-page="/Summary">Open summary</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm cardbox">
                <div class="card-body d-flex flex-column">
                    <h2 class="h5">Experience</h2>
                    <p class="flex-grow-1">Details about my work history and responsibilities.</p>
                    <a class="btn btn-primary mt-3 align-self-start" asp-page="/Experience">Open experience</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm cardbox">
                <div class="card-body d-flex flex-column">
                    <h2 class="h5">Projects</h2>
                    <p class="flex-grow-1">A showcase of applications and solutions I built.</p>
                    <a class="btn btn-primary mt-3 align-self-start" asp-page="/Projects">Open projects</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card h-100 shadow-sm cardbox">
                <div class="card-body d-flex flex-column">
                    <h2 class="h5">Education</h2>
                    <p class="flex-grow-1">My academic background and qualifications.</p>
                    <a class="btn btn-primary mt-3 align-self-start" asp-page="/Education">Open education</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm cardbox">
                <div class="card-body d-flex flex-column">
                    <h2 class="h5">Certifications</h2>
                    <p class="flex-grow-1">Training and certifications I have completed.</p>
                    <a class="btn btn-primary mt-3 align-self-start" asp-page="/Certifications">Open certifications</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm cardbox">
                <div class="card-body d-flex flex-column">
                    <h2 class="h5">Contact</h2>
                    <p class="flex-grow-1">How to reach me for work, questions, or collaborations.</p>
                    <a class="btn btn-primary mt-3 align-self-start" asp-page="/Contact">Open contact</a>
                </div>
            </div>
        </div>
        
       
    </section>

</div>
