@page
@{
    ViewData["Title"] = "Experience";
}

<div class="container py-5 experience-page">
    <div class="row">
        <div class="col-12">
            <header class="text-center mb-5">
                <h1 class="display-4 fw-bold mb-3">Professional Experience</h1>
                <p class="lead text-muted">My journey through software development and automotive applications</p>
            </header>
        </div>
    </div>

    <div class="timeline">
        <!-- Kani Solutions Inc -->
        <div class="timeline-item">
            <div class="timeline-marker"></div>
            <div class="timeline-content">
                <div class="experience-card">
                    <div class="card-header">
                        <div class="company-logo">
                            <img src="~/images/kani_solution_inc_logo.jpg" alt="Kani Solutions Inc Logo" class="company-logo-img" onerror="this.src='~/images/kani-logo.svg'">
                        </div>
                        <div class="job-info">
                            <h3 class="job-title">Software Engineer</h3>
                            <h4 class="company-name">Kani Solutions Inc</h4>
                            <p class="job-period">2024 - 2025</p>
                        </div>
                    </div>
                    <div class="card-body">
                        <p class="job-description">Contributed and tested scalable microservices and full-stack applications across banking, e-commerce, and insurance domains.</p>
                        <div class="tech-stack">
                            <span class="tech-badge">C++</span>
                            <span class="tech-badge">Java</span>
                            <span class="tech-badge">Spring Boot</span>
                            <span class="tech-badge">Angular</span>
                            <span class="tech-badge">React Native</span>
                            <span class="tech-badge">PostgreSQL</span>
                            <span class="tech-badge">MySQL</span>
                        </div>
                        <ul class="achievements">
                            <li>Created automated testing and CI/CD pipelines using Python, Docker, Kubernetes, Jenkins, and Git</li>
                            <li>Enhanced deployment reliability and integration efficiency</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <!-- ECARX -->
        <div class="timeline-item">
            <div class="timeline-marker"></div>
            <div class="timeline-content">
                <div class="experience-card">
                    <div class="card-header">
                        <div class="company-logo">
                            <img src="~/images/ecarx_logo.jpg" alt="ECARX Logo" class="company-logo-img" onerror="this.src='~/images/ecarx-logo.svg'">
                        </div>
                        <div class="job-info">
                            <h3 class="job-title">Automotive Application Developer</h3>
                            <h4 class="company-name">ECARX</h4>
                            <p class="job-period">2023 - 2024</p>
                        </div>
                    </div>
                    <div class="card-body">
                        <p class="job-description">Engineered automotive applications consulting with Volvo Cars, focusing on embedded systems and hardware integration.</p>
                        <div class="tech-stack">
                            <span class="tech-badge">C++</span>
                            <span class="tech-badge">Kotlin</span>
                            <span class="tech-badge">Java</span>
                            <span class="tech-badge">Linux</span>
                            <span class="tech-badge">Azure</span>
                            <span class="tech-badge">Raspberry Pi</span>
                        </div>
                        <ul class="achievements">
                            <li>Simulated and tested applications with Digital Human-Machine Interface (DHU)</li>
                            <li>Integrated hardware with ECU/MCU in Linux environments</li>
                            <li>Deployed scalable microservices on Azure cloud platform</li>
                            <li>Managed code with Git and Jira for version control and project management</li>
                            <li>Prototyped automotive solutions using Raspberry Pi to improve system reliability and development speed</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <!-- PlotEye -->
        <div class="timeline-item">
            <div class="timeline-marker"></div>
            <div class="timeline-content">
                <div class="experience-card">
                    <div class="card-header">
                        <div class="company-logo">
                            <img src="~/images/ploteye_logo.jpg" alt="PlotEye Logo" class="company-logo-img" onerror="this.src='~/images/ploteye-logo.svg'">
                        </div>
                        <div class="job-info">
                            <h3 class="job-title">Software Developer</h3>
                            <h4 class="company-name">PlotEye</h4>
                            <p class="job-period">2022 - 2023</p>
                        </div>
                    </div>
                    <div class="card-body">
                        <p class="job-description">Developed full-stack e-commerce solutions with focus on user experience and operational efficiency.</p>
                        <div class="tech-stack">
                            <span class="tech-badge">C#</span>
                            <span class="tech-badge">.NET</span>
                            <span class="tech-badge">SQL</span>
                            <span class="tech-badge">Payment Gateway</span>
                        </div>
                        <ul class="achievements">
                            <li>Developed a full-stack e-commerce web application implementing product catalog, shopping cart, and checkout workflow with secure payment gateway integration</li>
                            <li>Enhanced delivery accuracy by 95% resulting in streamlined operations and improved customer satisfaction</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sparly -->
        <div class="timeline-item">
            <div class="timeline-marker"></div>
            <div class="timeline-content">
                <div class="experience-card">
                    <div class="card-header">
                        <div class="company-logo">
                            <img src="~/images/sparly_logo.png" alt="Sparly Logo" class="company-logo-img">
                        </div>
                        <div class="job-info">
                            <h3 class="job-title">Front End Developer</h3>
                            <h4 class="company-name">Sparly</h4>
                            <p class="job-period">2021 - 2022</p>
                        </div>
                    </div>
                    <div class="card-body">
                        <p class="job-description">Built responsive web interfaces and maintained internal systems for improved user experience.</p>
                        <div class="tech-stack">
                            <span class="tech-badge">JavaScript</span>
                            <span class="tech-badge">SQL</span>
                            <span class="tech-badge">Entity Framework</span>
                            <span class="tech-badge">Frontend Frameworks</span>
                        </div>
                        <ul class="achievements">
                            <li>Developed customer-facing portals and internal dashboards</li>
                            <li>Worked with SQL, Entity Framework Core, and frontend frameworks</li>
                            <li>Maintained documentation and UI components</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="text-center mt-5">
        <a class="btn btn-primary btn-lg" asp-page="/Index">
            <span class="btn-icon">←</span> Back to Portfolio
        </a>
    </div>
</div>
