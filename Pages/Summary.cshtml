@page
@{
    ViewData["Title"] = "Summary";
}

<div class="container py-5 summary-page">
    <div class="row">
        <div class="col-12">
            <header class="text-center mb-5">
                <h1 class="display-4 fw-bold mb-3">Professional Summary</h1>
                <p class="lead text-muted">A passionate software engineer with 4 years of experience</p>
            </header>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="summary-card">
                <div class="card-body p-4">
                    <div class="experience-highlight mb-4">
                        <div class="highlight-icon">
                            <i class="fas fa-code"></i>
                        </div>
                        <div class="highlight-content">
                            <h3 class="highlight-title">4 Years of Experience</h3>
                            <p class="highlight-subtitle">Full-Stack Development & Automotive Applications</p>
                        </div>
                    </div>

                    <div class="summary-content">
                        <p class="summary-text">
                            Passionate software engineer with a strong foundation in developing impactful technology solutions across diverse industries including automotive, e-commerce, and financial services.
                        </p>

                        <div class="expertise-section mb-4">
                            <h4 class="expertise-title">Core Expertise</h4>
                            <div class="tech-stack">
                                <span class="tech-badge">C++</span>
                                <span class="tech-badge">C#</span>
                                <span class="tech-badge">.NET</span>
                                <span class="tech-badge">Java</span>
                                <span class="tech-badge">JavaScript</span>
                                <span class="tech-badge">Python</span>
                                <span class="tech-badge">Azure</span>
                                <span class="tech-badge">React</span>
                                <span class="tech-badge">Angular</span>
                            </div>
                        </div>

                        <p class="summary-text">
                            I excel in creating scalable microservices, full-stack applications, and embedded systems. My experience spans from developing automotive applications for Volvo Cars to building e-commerce platforms and banking solutions.
                        </p>

                        <div class="values-section">
                            <h4 class="values-title">What Drives Me</h4>
                            <ul class="values-list">
                                <li><i class="fas fa-check-circle"></i> Solving complex technical challenges</li>
                                <li><i class="fas fa-check-circle"></i> Collaborating with cross-functional teams</li>
                                <li><i class="fas fa-check-circle"></i> Delivering high-quality, user-focused solutions</li>
                                <li><i class="fas fa-check-circle"></i> Continuous learning and innovation</li>
                                <li><i class="fas fa-check-circle"></i> Making technology accessible and impactful</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="text-center mt-5">
        <a class="btn btn-primary btn-lg" asp-page="/Index">
            <span class="btn-icon">←</span> Back to Portfolio
        </a>
    </div>
</div>
