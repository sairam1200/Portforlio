@page
@{
    ViewData["Title"] = "Contact";
}

<div class="container py-5 contact-page">
    <div class="row">
        <div class="col-12">
            <header class="text-center mb-5">
                <h1 class="display-4 fw-bold mb-3">Get In Touch</h1>
                <p class="lead">Let's connect and collaborate</p>
            </header>
        </div>
    </div>
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="contact-card">
                <div class="card-body p-4">
                    <div class="contact-item">
                        <div class="contact-icon">
                            <i class="fas fa-envelope"></i>
                        </div>
                        <div class="contact-content">
                            <h4>Email</h4>
                            <p class="contact-detail">
                                <a href="mailto:sairamch@gmail.com">sairamch@gmail.com</a>
                            </p>
                        </div>
                    </div>

                    <div class="contact-item">
                        <div class="contact-icon">
                            <i class="fas fa-phone"></i>
                        </div>
                        <div class="contact-content">
                            <h4>Phone</h4>
                            <p class="contact-detail">
                                <a href="tel:+46793574689">+46 79 357 46 89</a>
                            </p>
                        </div>
                    </div>

                    <div class="contact-item">
                        <div class="contact-icon">
                            <i class="fab fa-linkedin"></i>
                        </div>
                        <div class="contact-content">
                            <h4>LinkedIn</h4>
                            <p class="contact-detail">
                                <a href="https://www.linkedin.com/in/sairam-chikkala/" target="_blank">linkedin.com/in/sairam-chikkala</a>
                            </p>
                        </div>
                    </div>

                    <div class="contact-item">
                        <div class="contact-icon">
                            <i class="fab fa-github"></i>
                        </div>
                        <div class="contact-content">
                            <h4>GitHub</h4>
                            <p class="contact-detail">
                                <a href="https://github.com/sairam1200" target="_blank">github.com/sairam1200</a>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="text-center mt-5">
        <a class="btn btn-primary btn-lg" asp-page="/Index">
            <span class="btn-icon">←</span> Back to Portfolio
        </a>
    </div>
